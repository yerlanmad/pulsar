<%= form_with(model: route_rule, class: 'space-y-6 max-w-lg') do |f| %>
  <% if route_rule.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% route_rule.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: 'block text-sm font-medium text-gray-700' %>
    <%= f.text_field :name, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm', required: true, placeholder: 'e.g. US Support Line' %>
  </div>

  <div>
    <%= f.label :pattern, 'Number Pattern', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.text_field :pattern, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono', required: true, placeholder: 'e.g. +1800*' %>
    <p class="mt-1 text-xs text-gray-500">Use * as wildcard. Incoming numbers matching this pattern will be routed to the selected queue.</p>
  </div>

  <div>
    <%= f.label :queue_config_id, 'Destination Queue', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.collection_select :queue_config_id, @queue_configs, :id, :name, { prompt: 'Select queue' }, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>
  </div>

  <div>
    <%= f.label :position, 'Priority (lower = higher priority)', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.number_field :position, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm', min: 0 %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer' %>
    <%= link_to 'Cancel', route_rules_path, class: 'rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50' %>
  </div>
<% end %>
