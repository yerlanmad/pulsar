<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Route Rules</h1>
  <% if policy(RouteRule).create? %>
    <%= link_to 'New Rule', new_route_rule_path, class: 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500' %>
  <% end %>
</div>

<div class="overflow-hidden rounded-lg bg-white shadow">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Position</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Pattern</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Queue</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 bg-white">
      <% @route_rules.each do |rule| %>
        <tr>
          <td class="px-6 py-4 text-sm text-gray-500"><%= rule.position %></td>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= rule.name %></td>
          <td class="px-6 py-4 text-sm font-mono text-gray-700"><%= rule.pattern %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= rule.queue_config.name %></td>
          <td class="px-6 py-4 text-right text-sm space-x-2">
            <% if policy(rule).update? %>
              <%= link_to 'Edit', edit_route_rule_path(rule), class: 'text-indigo-600 hover:text-indigo-800' %>
            <% end %>
            <% if policy(rule).destroy? %>
              <%= button_to 'Delete', route_rule_path(rule), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'text-red-600 hover:text-red-800' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
