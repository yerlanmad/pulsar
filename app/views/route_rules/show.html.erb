<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @route_rule.name %></h1>
</div>

<div class="bg-white shadow rounded-lg p-6">
  <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <dt class="text-sm font-medium text-gray-500">Pattern</dt>
      <dd class="mt-1 text-sm font-mono text-gray-900"><%= @route_rule.pattern %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Destination Queue</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @route_rule.queue_config.name %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Priority</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @route_rule.position %></dd>
    </div>
  </dl>
</div>
