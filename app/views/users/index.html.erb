<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Users</h1>
  <%= link_to 'New User', new_user_path, class: 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500' %>
</div>

<div class="overflow-hidden rounded-lg bg-white shadow">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 bg-white">
      <% @users.each do |user| %>
        <tr>
          <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= user.name %></td>
          <td class="px-6 py-4 text-sm text-gray-500"><%= user.email_address %></td>
          <td class="px-6 py-4 text-sm"><%= status_badge(user.role) %></td>
          <td class="px-6 py-4 text-right text-sm space-x-2">
            <%= link_to 'Edit', edit_user_path(user), class: 'text-indigo-600 hover:text-indigo-800' %>
            <% if user != Current.user %>
              <%= button_to 'Delete', user_path(user), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'text-red-600 hover:text-red-800' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
