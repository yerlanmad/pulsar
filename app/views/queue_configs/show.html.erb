<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @queue_config.name %></h1>
  <div class="flex gap-3">
    <% if policy(@queue_config).update? %>
      <%= link_to 'Edit', edit_queue_config_path(@queue_config), class: 'rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50' %>
    <% end %>
    <% if policy(@queue_config).destroy? %>
      <%= button_to 'Delete', queue_config_path(@queue_config), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white hover:bg-red-500' %>
    <% end %>
  </div>
</div>

<div class="bg-white shadow rounded-lg p-6 mb-6">
  <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div>
      <dt class="text-sm font-medium text-gray-500">Strategy</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @queue_config.strategy.humanize %></dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Ring Timeout</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @queue_config.timeout %>s</dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Max Wait Time</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @queue_config.max_wait_time %>s</dd>
    </div>
    <div>
      <dt class="text-sm font-medium text-gray-500">Timeout Action</dt>
      <dd class="mt-1 text-sm text-gray-900"><%= @queue_config.timeout_action.humanize %></dd>
    </div>
  </dl>
</div>

<div class="bg-white shadow rounded-lg p-6 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Agents in Queue</h2>
  </div>

  <% if @queue_config.queue_memberships.any? %>
    <table class="min-w-full divide-y divide-gray-200 mb-4">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Agent</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Priority</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @queue_config.queue_memberships.includes(:agent).order(:priority).each do |membership| %>
          <tr>
            <td class="px-6 py-4 text-sm font-medium text-gray-900"><%= membership.agent.name %></td>
            <td class="px-6 py-4 text-sm"><%= status_badge(membership.agent.status) %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= membership.priority %></td>
            <td class="px-6 py-4 text-right text-sm">
              <% if policy(@queue_config).update? %>
                <%= button_to 'Remove', queue_config_queue_membership_path(@queue_config, membership), method: :delete, class: 'text-red-600 hover:text-red-800' %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-gray-500 mb-4">No agents assigned to this queue.</p>
  <% end %>

  <% if policy(@queue_config).update? && @available_agents.any? %>
    <div class="border-t pt-4">
      <h3 class="text-sm font-medium text-gray-700 mb-2">Add Agent</h3>
      <%= form_with(model: [@queue_config, QueueMembership.new], class: 'flex gap-3 items-end') do |f| %>
        <div class="flex-1">
          <%= f.collection_select :agent_id, @available_agents, :id, :name, { prompt: 'Select agent' }, class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>
        </div>
        <div class="w-24">
          <%= f.number_field :priority, value: 0, min: 0, placeholder: 'Priority', class: 'block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>
        </div>
        <%= f.submit 'Add', class: 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer' %>
      <% end %>
    </div>
  <% end %>
</div>
