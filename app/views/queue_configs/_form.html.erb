<%= form_with(model: queue_config, class: 'space-y-6 max-w-lg') do |f| %>
  <% if queue_config.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="list-disc pl-5 text-sm text-red-700">
        <% queue_config.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: 'block text-sm font-medium text-gray-700' %>
    <%= f.text_field :name, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm', required: true %>
  </div>

  <div>
    <%= f.label :strategy, class: 'block text-sm font-medium text-gray-700' %>
    <%= f.select :strategy, QueueConfig.strategies.keys.map { |s| [s.humanize, s] }, {}, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>
  </div>

  <div>
    <%= f.label :timeout, 'Agent Ring Timeout (seconds)', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.number_field :timeout, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm', min: 1 %>
  </div>

  <div>
    <%= f.label :max_wait_time, 'Max Wait Time (seconds)', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.number_field :max_wait_time, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm', min: 1 %>
  </div>

  <div>
    <%= f.label :timeout_action, 'Action on Timeout', class: 'block text-sm font-medium text-gray-700' %>
    <%= f.select :timeout_action, QueueConfig.timeout_actions.keys.map { |s| [s.humanize, s] }, {}, class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm' %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500 cursor-pointer' %>
    <%= link_to 'Cancel', queue_configs_path, class: 'rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50' %>
  </div>
<% end %>
