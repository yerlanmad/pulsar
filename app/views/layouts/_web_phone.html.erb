<div data-controller="web-phone"
     data-web-phone-credentials-url-value="<%= web_phone_credentials_path %>"
     data-state="idle"
     class="fixed bottom-4 right-4 z-50">

  <%# Floating toggle button %>
  <button data-action="web-phone#togglePanel"
          data-web-phone-target="toggleButton"
          class="flex items-center gap-2 rounded-full bg-indigo-600 px-4 py-2.5 text-sm font-medium text-white shadow-lg hover:bg-indigo-500 transition-colors">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
    </svg>
    <span data-web-phone-target="status" class="text-xs">Offline</span>
    <span class="relative flex h-2.5 w-2.5">
      <span data-state-dot class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75"
            style="display:none"></span>
      <span data-state-dot-solid class="relative inline-flex rounded-full h-2.5 w-2.5 bg-gray-400"></span>
    </span>
  </button>

  <%# Phone panel %>
  <div data-web-phone-target="panel" class="hidden absolute bottom-14 right-0 w-72 rounded-2xl bg-white shadow-2xl ring-1 ring-gray-200 overflow-hidden">

    <%# Header %>
    <div class="bg-indigo-600 px-4 py-3 text-white">
      <div class="flex items-center justify-between">
        <span class="text-sm font-semibold"><%= t('web_phone.title') %></span>
        <span data-web-phone-target="callTimer" class="text-xs font-mono">00:00</span>
      </div>
      <p data-web-phone-target="callerInfo" class="text-xs text-indigo-200 mt-0.5 truncate"></p>
    </div>

    <%# Incoming call alert %>
    <div data-web-phone-target="incomingAlert" class="hidden bg-green-50 px-4 py-3 border-b border-green-200">
      <p class="text-sm font-medium text-green-800 mb-2"><%= t('web_phone.incoming_call') %></p>
      <div class="flex gap-2">
        <button data-action="web-phone#answer"
                data-web-phone-target="answerButton"
                class="flex-1 rounded-lg bg-green-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-green-500">
          <%= t('web_phone.answer') %>
        </button>
        <button data-action="web-phone#reject"
                data-web-phone-target="rejectButton"
                class="flex-1 rounded-lg bg-red-600 px-3 py-1.5 text-xs font-medium text-white hover:bg-red-500">
          <%= t('web_phone.reject') %>
        </button>
      </div>
    </div>

    <%# Dial input %>
    <div class="px-4 pt-3 pb-2">
      <div class="flex items-center gap-2">
        <input type="text"
               data-web-phone-target="dialInput"
               placeholder="<%= t('web_phone.enter_number') %>"
               class="flex-1 rounded-lg border-gray-300 text-sm px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500">
        <button data-action="web-phone#backspace"
                class="text-gray-400 hover:text-gray-600 p-1">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9.75L14.25 12m0 0l2.25 2.25M14.25 12l2.25-2.25M14.25 12L12 14.25m-2.58 4.92l-6.375-6.375a1.125 1.125 0 010-1.59L9.42 4.83c.211-.211.498-.33.796-.33H19.5a2.25 2.25 0 012.25 2.25v10.5a2.25 2.25 0 01-2.25 2.25h-9.284c-.298 0-.585-.119-.796-.33z" />
          </svg>
        </button>
      </div>
    </div>

    <%# Dialpad %>
    <div data-web-phone-target="dialpad" class="px-4 pb-2">
      <div class="grid grid-cols-3 gap-1.5">
        <% %w[1 2 3 4 5 6 7 8 9 * 0 #].each do |key| %>
          <button data-action="web-phone#dialKey"
                  data-key="<%= key %>"
                  class="rounded-lg bg-gray-50 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-100 active:bg-gray-200 transition-colors">
            <%= key %>
          </button>
        <% end %>
      </div>
    </div>

    <%# Call controls %>
    <div class="px-4 pb-3 flex gap-2">
      <button data-action="web-phone#dial"
              data-web-phone-target="callButton"
              class="flex-1 rounded-lg bg-green-600 px-3 py-2 text-sm font-medium text-white hover:bg-green-500 transition-colors">
        <%= t('web_phone.call') %>
      </button>
      <button data-action="web-phone#hangup"
              data-web-phone-target="hangupButton"
              class="hidden flex-1 rounded-lg bg-red-600 px-3 py-2 text-sm font-medium text-white hover:bg-red-500 transition-colors">
        <%= t('web_phone.hangup') %>
      </button>
      <button data-action="web-phone#toggleMute"
              data-web-phone-target="muteButton"
              data-muted="false"
              class="hidden rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 transition-colors">
        <%= t('web_phone.mute') %>
      </button>
    </div>

    <%# DTMF pad (visible during call) %>
    <div data-in-call-only class="hidden px-4 pb-3">
      <div class="grid grid-cols-3 gap-1.5">
        <% %w[1 2 3 4 5 6 7 8 9 * 0 #].each do |digit| %>
          <button data-action="web-phone#sendDtmf"
                  data-digit="<%= digit %>"
                  class="rounded-lg bg-gray-50 py-2 text-xs font-medium text-gray-600 hover:bg-gray-100">
            <%= digit %>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# Hidden audio element for remote stream %>
  <audio data-web-phone-target="audio" autoplay></audio>
</div>

<style>
  [data-controller="web-phone"][data-state="registered"] [data-state-dot] {
    display: inline-flex !important;
    background-color: rgb(34 197 94);
  }
  [data-controller="web-phone"][data-state="registered"] [data-state-dot-solid] {
    background-color: rgb(34 197 94);
  }
  [data-controller="web-phone"][data-state="in_call"] [data-state-dot-solid] {
    background-color: rgb(234 179 8);
  }
  [data-controller="web-phone"][data-state="in_call"] [data-state-dot] {
    display: none !important;
  }
  [data-controller="web-phone"][data-state="ringing_in"] [data-state-dot] {
    display: inline-flex !important;
    background-color: rgb(34 197 94);
  }
  [data-controller="web-phone"][data-state="ringing_in"] [data-state-dot-solid] {
    background-color: rgb(34 197 94);
  }
  [data-controller="web-phone"][data-state="registering"] [data-state-dot-solid] {
    background-color: rgb(234 179 8);
  }

  /* Show/hide controls based on state */
  [data-controller="web-phone"][data-state="ringing_in"] [data-web-phone-target="incomingAlert"] {
    display: block !important;
  }
  [data-controller="web-phone"][data-state="in_call"] [data-web-phone-target="callButton"] {
    display: none !important;
  }
  [data-controller="web-phone"][data-state="in_call"] [data-web-phone-target="hangupButton"] {
    display: block !important;
  }
  [data-controller="web-phone"][data-state="in_call"] [data-web-phone-target="muteButton"] {
    display: block !important;
  }
  [data-controller="web-phone"][data-state="in_call"] [data-in-call-only] {
    display: block !important;
  }
  [data-controller="web-phone"][data-state="in_call"] [data-web-phone-target="dialpad"] {
    display: none !important;
  }
  [data-controller="web-phone"][data-state="ringing_out"] [data-web-phone-target="callButton"] {
    display: none !important;
  }
  [data-controller="web-phone"][data-state="ringing_out"] [data-web-phone-target="hangupButton"] {
    display: block !important;
  }
</style>
