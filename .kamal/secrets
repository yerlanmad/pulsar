# Secrets for Kamal deployment.
# Pull from environment variables or password manager. DO NOT ENTER RAW CREDENTIALS HERE!

RAILS_MASTER_KEY=$(cat config/master.key)

# Container registry credentials (set these in your shell env)
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Asterisk credentials
ASTERISK_ARI_PASS=$ASTERISK_ARI_PASS
ASTERISK_AMI_SECRET=$ASTERISK_AMI_SECRET

# Deploy target
DEPLOY_HOST=$DEPLOY_HOST
